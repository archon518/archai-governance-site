






.h-wordmark{
  font-family:'Cinzel',serif;font-weight:900;
  font-size:clamp(5rem,18vw,11.5rem);letter-spacing:.22em;line-height:1;
  color:var(--ivory);opacity:0;animation:fade-up 1s .4s ease forwards;
}
.h-wordmark .acc{color:var(--gold)}
.h-rule{
  width:52px;height:1px;background:var(--gold-soft);
  margin:2.5rem auto;opacity:0;animation:fade-in .8s 1.1s ease forwards;
}
.h-identity{
  font-family:'Cinzel',serif;font-size:clamp(.7rem,1.6vw,.95rem);
  letter-spacing:.35em;text-transform:uppercase;color:var(--mist);
  margin-bottom:1.2rem;opacity:0;animation:fade-up .8s 1.3s ease forwards;
}
.h-desc{
  max-width:520px;font-size:.93rem;font-style:italic;
  color:var(--mist);line-height:1.95;margin-bottom:3rem;
  opacity:0;animation:fade-up .9s 1.5s ease forwards;
}
.h-badges{
  display:flex;gap:.6rem;flex-wrap:wrap;justify-content:center;
  margin-bottom:3.5rem;opacity:0;animation:fade-in .8s 1.7s ease forwards;
}
.badge{
  font-family:'Cinzel',serif;font-size:.5rem;letter-spacing:.25em;text-transform:uppercase;
  color:var(--mist);border:1px solid var(--fog);padding:.5em 1em;
  transition:border-color .3s,color .3s;
}
.badge:hover{border-color:var(--gold-soft);color:var(--ivory)}
.h-ctas{
  display:flex;gap:1rem;flex-wrap:wrap;justify-content:center;
  opacity:0;animation:fade-up .8s 1.9s ease forwards;
}
.btn-gold{
  font-family:'Cinzel',serif;font-size:.6rem;letter-spacing:.4em;text-transform:uppercase;
  color:var(--bg);background:var(--gold);padding:1.1rem 2.8rem;
  text-decoration:none;transition:background .25s,transform .2s;display:inline-block;
}
.btn-gold:hover{background:var(--ivory);transform:translateY(-2px)}
.btn-ghost{
  font-family:'Cinzel',serif;font-size:.6rem;letter-spacing:.4em;text-transform:uppercase;
  color:var(--gold);border:1px solid var(--fog);padding:1.1rem 2.8rem;
  text-decoration:none;transition:border-color .25s,color .25s;display:inline-block;
}
.btn-ghost:hover{border-color:var(--gold);color:var(--ivory)}

/* scroll cue */
.h-scroll{
  position:absolute;bottom:2.5rem;left:50%;transform:translateX(-50%);
  display:flex;flex-direction:column;align-items:center;gap:.6rem;
  opacity:0;animation:fade-in 1s 2.4s ease forwards;
}
.h-scroll span{font-family:'Cinzel',serif;font-size:.45rem;letter-spacing:.55em;text-transform:uppercase;color:var(--fog)}
.scroll-line{width:1px;height:44px;background:linear-gradient(to bottom,var(--gold-soft),transparent);animation:sp 2s ease-in-out infinite}
@keyframes sp{0%,100%{opacity:.35}50%{opacity:1}}

/* ── AUTHORITY STRIP ── */
.auth-strip{
  border-top:1px solid var(--rule);border-bottom:1px solid var(--rule);
  background:var(--surface);padding:2rem 3.5rem;
  display:grid;grid-template-columns:repeat(4,1fr);gap:1px;
  background:var(--rule);
}
.auth-item{
  background:var(--surface);padding:1.6rem 2rem;
  display:flex;flex-direction:column;gap:.4rem;
}
.auth-label{font-family:'Cinzel',serif;font-size:.48rem;letter-spacing:.45em;text-transform:uppercase;color:var(--fog)}
.auth-value{font-family:'Cinzel',serif;font-size:.82rem;letter-spacing:.1em;color:var(--ivory)}
.auth-value span{color:var(--gold)}

/* ── TICKER ── */
.ticker{border-bottom:1px solid var(--rule);background:var(--bg);padding:.85rem 0;overflow:hidden;white-space:nowrap}
.ticker-track{display:inline-block;animation:tick 28s linear infinite}
.ticker-item{display:inline-block;font-family:'Cinzel',serif;font-size:.55rem;letter-spacing:.3em;text-transform:uppercase;color:var(--fog);padding:0 2.5rem}
.ticker-item::after{content:'◆';margin-left:2.5rem;color:var(--rule)}
@keyframes tick{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

/* ── SECTIONS ── */
.section{padding:7rem 3.5rem;max-width:1200px;margin:0 auto;border-top:1px solid var(--rule)}
.eyebrow{font-family:'Cinzel',serif;font-size:.53rem;letter-spacing:.55em;text-transform:uppercase;color:var(--gold-soft);display:flex;align-items:center;gap:1.5rem;margin-bottom:4rem}
.eyebrow::after{content:'';flex:1;height:1px;background:var(--rule)}

/* ── WHAT ── */
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:start}
.s-headline{font-family:'Cinzel',serif;font-weight:600;font-size:clamp(1.4rem,2.6vw,2rem);line-height:1.3;color:var(--ivory);margin-bottom:2rem}
.s-headline em{font-style:normal;color:var(--gold)}
.body-text{font-size:.87rem;color:var(--mist);line-height:2;margin-bottom:1.4rem}
.reg-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--rule)}
.reg-item{background:var(--card);padding:1.8rem 2rem}
.r-name{font-family:'Cinzel',serif;font-size:.72rem;letter-spacing:.15em;color:var(--ivory);margin-bottom:.4rem}
.r-desc{font-size:.72rem;color:var(--mist);line-height:1.6}

/* ── NOT ARCHAI ── */
.not-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--rule);margin-top:3rem}
.not-card{background:var(--card);padding:2rem 2.2rem}
.not-label{font-family:'Cinzel',serif;font-size:.5rem;letter-spacing:.4em;text-transform:uppercase;margin-bottom:.8rem}
.not-label.red{color:#8B3A3A}
.not-label.gold{color:var(--gold-soft)}
.not-list{list-style:none;display:flex;flex-direction:column;gap:.6rem}
.not-list li{font-size:.8rem;color:var(--mist);line-height:1.6;padding-left:1.2rem;position:relative}
.not-list li::before{position:absolute;left:0;font-size:.7rem}
.not-list.no li::before{content:'✗';color:#6B3A3A}
.not-list.yes li::before{content:'✓';color:var(--gold-soft)}

/* ── PROFIT STACK ── */
.stack-intro{max-width:580px;margin-bottom:3.5rem}
.stack-intro p{font-size:.87rem;color:var(--mist);line-height:2}
.stack-rows{display:flex;flex-direction:column;gap:1px;background:var(--rule)}
.stack-row{background:var(--card);padding:2rem 2.5rem;display:grid;grid-template-columns:9rem 1fr auto;align-items:center;gap:2rem;transition:background .25s;cursor:default}
.stack-row:hover{background:#1A1814}
.stack-row.active{background:#1C1A10;border-left:2px solid var(--gold)}
.sr-num{font-family:'Cinzel',serif;font-size:.48rem;letter-spacing:.45em;color:var(--fog);white-space:nowrap}
.sr-name{font-family:'Cinzel',serif;font-weight:600;font-size:.88rem;letter-spacing:.14em;color:var(--ivory);margin-bottom:.25rem}
.sr-name.gold{color:var(--gold)}
.sr-desc{font-size:.75rem;color:var(--mist);line-height:1.6}
.sr-tag{font-family:'Cinzel',serif;font-size:.45rem;letter-spacing:.3em;text-transform:uppercase;color:var(--mist);white-space:nowrap;text-align:right}
.sr-tag.gold{color:var(--gold)}

/* ── DIAGNOSTIC ── */
.diag-layout{display:grid;grid-template-columns:3fr 2fr;gap:5rem;align-items:start}
.diag-steps{display:flex;flex-direction:column;gap:1px;background:var(--rule);margin-top:2rem}
.diag-step{background:var(--card);padding:1.8rem 2.2rem;display:grid;grid-template-columns:2.5rem 1fr;gap:1.5rem;align-items:start}
.ds-num{font-family:'Cinzel',serif;font-weight:700;font-size:1.4rem;color:var(--gold);line-height:1}
.ds-title{font-family:'Cinzel',serif;font-size:.78rem;letter-spacing:.1em;color:var(--ivory);margin-bottom:.4rem}
.ds-desc{font-size:.75rem;color:var(--mist);line-height:1.7}
.diag-cta-block{background:var(--card);border:1px solid var(--rule);border-top:2px solid var(--gold);padding:2.8rem 2.4rem;display:flex;flex-direction:column;gap:1.5rem;position:sticky;top:6rem}
.dcb-label{font-family:'Cinzel',serif;font-size:.5rem;letter-spacing:.45em;text-transform:uppercase;color:var(--gold-soft)}
.dcb-title{font-family:'Cinzel',serif;font-weight:600;font-size:1.1rem;letter-spacing:.1em;color:var(--ivory);line-height:1.3}
.dcb-desc{font-size:.78rem;color:var(--mist);line-height:1.8}
.dcb-note{font-size:.7rem;color:var(--fog);font-style:italic}

/* ── MECHANISMS ── */
.mech-intro{max-width:620px;margin-bottom:3.5rem}
.mech-intro p{font-size:.87rem;color:var(--mist);line-height:2}
.mech-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--rule)}
.mech-card{background:var(--card);padding:2.4rem 2rem;display:flex;flex-direction:column;gap:.7rem;position:relative;overflow:hidden;transition:background .3s}
.mech-card::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:var(--gold);transform:scaleX(0);transform-origin:left;transition:transform .4s}
.mech-card:hover{background:#1A1814}
.mech-card:hover::after{transform:scaleX(1)}
.mc-idx{font-family:'Cinzel',serif;font-size:.48rem;letter-spacing:.5em;color:var(--fog)}
.mc-name{font-family:'Cinzel',serif;font-weight:600;font-size:.95rem;letter-spacing:.12em;color:var(--ivory)}
.mc-name .g{color:var(--gold)}
.mc-role{font-size:.6rem;letter-spacing:.15em;text-transform:uppercase;color:var(--gold-soft)}
.mc-desc{font-size:.78rem;color:var(--mist);line-height:1.8;flex:1}
.mc-tool{font-size:.7rem;color:var(--mist);border-top:1px solid var(--rule);padding-top:.8rem;margin-top:.3rem}
.mc-tool strong{color:var(--gold);font-weight:400}
.mc-link{font-family:'Cinzel',serif;font-size:.55rem;letter-spacing:.3em;text-transform:uppercase;color:var(--gold);text-decoration:none;display:inline-flex;align-items:center;gap:.6rem;transition:gap .3s;margin-top:auto}
.mc-link::after{content:'→'}
.mc-link:hover{gap:1.2rem}
.mech-note{font-size:.72rem;color:var(--fog);margin-top:3rem;font-style:italic}

/* ── PRICING ── */
.price-intro{max-width:540px;margin-bottom:3.5rem}
.price-intro p{font-size:.87rem;color:var(--mist);line-height:2}
.price-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--rule)}
.price-card{background:var(--card);padding:3rem 2.4rem;display:flex;flex-direction:column;position:relative}
.price-card.featured{background:#1C1A10;border-top:2px solid var(--gold)}
.most-badge{position:absolute;top:1.2rem;right:1.2rem;font-family:'Cinzel',serif;font-size:.45rem;letter-spacing:.3em;text-transform:uppercase;color:var(--bg);background:var(--gold);padding:.4em .9em}
.p-tier{font-family:'Cinzel',serif;font-size:.48rem;letter-spacing:.5em;text-transform:uppercase;color:var(--mist);margin-bottom:1.5rem}
.p-name{font-family:'Cinzel',serif;font-weight:600;font-size:1.05rem;letter-spacing:.1em;color:var(--ivory);margin-bottom:.3rem}
.p-sub{font-size:.72rem;color:var(--mist);margin-bottom:2rem;line-height:1.5}
.p-amount{font-family:'Cinzel',serif;font-weight:700;font-size:2.2rem;color:var(--gold);line-height:1;margin-bottom:.4rem}
.p-cadence{font-size:.65rem;color:var(--mist);margin-bottom:2rem}
.p-features{list-style:none;display:flex;flex-direction:column;gap:.8rem;margin-bottom:2.5rem;padding-top:1.5rem;border-top:1px solid var(--rule);flex:1}
.p-features li{font-size:.78rem;color:var(--mist);line-height:1.6;padding-left:1.3rem;position:relative}
.p-features li::before{content:'✓';position:absolute;left:0;color:var(--gold-soft);font-size:.7rem}
.p-cta{font-family:'Cinzel',serif;font-size:.58rem;letter-spacing:.35em;text-transform:uppercase;text-decoration:none;padding:1rem 1.5rem;text-align:center;transition:background .25s,color .25s;margin-top:auto;display:block}
.p-cta.primary{background:var(--gold);color:var(--bg)}
.p-cta.primary:hover{background:var(--ivory)}
.p-cta.ghost{border:1px solid var(--fog);color:var(--gold)}
.p-cta.ghost:hover{border-color:var(--gold);color:var(--ivory)}

/* ── FOOTER ── */
footer{border-top:1px solid var(--rule);padding:2.4rem 3.5rem;max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem}
.f-brand{font-family:'Cinzel',serif;font-weight:600;font-size:.7rem;letter-spacing:.4em;color:var(--gold-soft)}
.f-copy{font-size:.68rem;color:var(--mist)}
.f-nav{display:flex;gap:2rem;list-style:none}
.f-nav a{font-family:'Cinzel',serif;font-size:.5rem;letter-spacing:.3em;text-transform:uppercase;color:var(--mist);text-decoration:none;transition:color .25s}
.f-nav a:hover{color:var(--gold)}

/* ── REVEAL ── */
.reveal{opacity:0;transform:translateY(22px);transition:opacity .75s ease,transform .75s ease}
.reveal.visible{opacity:1;transform:none}

@keyframes fade-up{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
@keyframes fade-in{from{opacity:0}to{opacity:1}}

/* ── RESPONSIVE ── */
@media(max-width:960px){
  nav{padding:1.2rem 1.8rem}
  .nav-links{display:none}
  .section{padding:5rem 1.8rem}
  .auth-strip{grid-template-columns:1fr 1fr}
  .two-col,.diag-layout,.not-grid{grid-template-columns:1fr;gap:3rem}
  .mech-grid{grid-template-columns:1fr 1fr}
  .stack-row{grid-template-columns:1fr;gap:.5rem}
  .sr-tag{text-align:left}
  .price-grid{grid-template-columns:1fr}
  .diag-cta-block{position:static}
  footer{padding:2rem 1.8rem;flex-direction:column;align-items:flex-start}
}
@media(max-width:600px){
  .mech-grid{grid-template-columns:1fr}
  .reg-grid{grid-template-columns:1fr}
  .auth-strip{grid-template-columns:1fr}
  .meridian{display:none}
  .hero-glow{width:320px;height:320px}
}
@media(prefers-reduced-motion:reduce){
  .hero-glow,.scroll-line,.ticker-track{animation:none}
  .meridian{animation:none;opacity:.12}
  .h-kicker,.h-wordmark,.h-rule,.h-identity,.h-desc,.h-badges,.h-ctas,.h-scroll{animation:none;opacity:1}
  .reveal{opacity:1;transform:none;transition:none}
}
</style>index.html
</head>
